COMPOSE_PROJECT_NAME=aas-learning
LOCAL_UID=1000
LOCAL_GID=1000

# Pinned server release published 2026-06-04.
BASYX_VERSION=2.0.0-milestone-11

# BaSyx GUI has no stable semantic-version tag. This immutable commit tag is
# intentionally pinned and reviewed through scripts/check-image-tags.sh.
AAS_GUI_VERSION=8c601af

MONGO_VERSION=8.0.12
MOSQUITTO_VERSION=2.0.22
PYTHON_VERSION=3.13.5-alpine3.22

# Development-only credentials. Replace for any shared deployment.
MONGO_ROOT_USERNAME=aas_admin
MONGO_ROOT_PASSWORD=aas_dev_password
